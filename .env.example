# Gemini API key (required for question generation & recommendations)
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: Gemini model name
# GEMINI_MODEL_NAME=gemini-2.5-flash

# Model paths (defaults are fine for standard layout)
# DEPRESSION_MODEL_PATH=models/depression/phq_xgb.pkl
# ANXIETY_MODEL_PATH=models/anxiety/gbr_pipeline.joblib

# Audio
# SAMPLE_RATE=16000
# ANXIETY_N_MFCC=40

# Server
# HOST=0.0.0.0
# PORT=8001
# CORS_ORIGINS=*

# Interview
# TOTAL_QUESTIONS=5

# SER model load timeout (seconds, 0 to disable)
# SER_LOAD_TIMEOUT=120
